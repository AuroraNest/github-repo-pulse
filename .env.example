# RepoPulse placeholder configuration. Do not put production secrets here.
NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-local-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-locally

# MySQL is the first-class backend for this implementation.
DATABASE_URL=mysql://repopulse_user:replace-with-local-password@127.0.0.1:3306/repopulse_dev

# GitHub integration. Leave empty to show a configuration-required empty state.
# Set MOCK_GITHUB=true only when you explicitly want demo data.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
MOCK_GITHUB=false
SYNC_CONCURRENCY=3

# Optional AI provider. Leave disabled for rule-based reports.
AI_ENABLED=false
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
